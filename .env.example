DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=paperclip-dev-secret

# Linear OAuth (optional — enables Linear integration)
# Create an OAuth app at https://linear.app/settings/api/applications
PAPERCLIP_LINEAR_CLIENT_ID=
PAPERCLIP_LINEAR_CLIENT_SECRET=
# PAPERCLIP_LINEAR_REDIRECT_URI=http://localhost:3100/api/auth/linear/callback

# Linear personal API key (optional — lets tooling create/read issues
# directly, without going through the OAuth plugin). Get one at
# Linear → Settings → API → Personal API keys.
LINEAR_API_KEY=

# ---------------------------------------------------------------------------
# Plugin bootstrap credentials
#
# The `server/src/auto-seed.ts` module reads these at boot (and after each
# company creation) to materialize host secrets and wire plugin instance
# configs automatically. Everything below is optional — set only the keys
# for the plugins you want to use, and the rest stay disconnected.
# ---------------------------------------------------------------------------

# FRED — free API key from https://fred.stlouisfed.org/docs/api/api_key.html
# (seeds `research-fred-api-key` secret, feeds the research plugin)
FRED_API_KEY=

# Tavily — https://tavily.com (free tier). Seeds `research-tavily-api-key`.
TAVILY_API_KEY=

# SEC EDGAR requires a User-Agent with contact info per their fair-access
# policy. Inlined into the research plugin config (not a secret).
SEC_EDGAR_USER_AGENT="Lucitra Research contact@lucitra.ai"

# Alpaca (market-data plugin). Seeds `market-data-alpaca-key-id` and
# `market-data-alpaca-secret`.
ALPACA_API_KEY_ID=
ALPACA_SECRET_KEY=

# Finnhub (market-data plugin, optional). Seeds `market-data-finnhub-api-key`.
FINNHUB_API_KEY=

# Kalshi (kalshi plugin). Demo and prod are separate account systems;
# configure whichever you need. `KALSHI_ENV` sets the plugin's defaultEnv
# (falls back to "demo" if unset). PEM files can't live in `.env` —
# reference them by path (absolute, `~/`-prefixed, or relative to
# `paperclip/server/`, which is the dev-server cwd).
#
# Generate keys in each env's web UI under Account → API Keys.
KALSHI_ENV=demo
KALSHI_DEMO_API_KEY_ID=
KALSHI_DEMO_PRIVATE_KEY_PATH=../paperclip-plugin-kalshi/.kalshi-demo-key.pem
KALSHI_PROD_API_KEY_ID=
KALSHI_PROD_PRIVATE_KEY_PATH=../paperclip-plugin-kalshi/.kalshi-prod-key.pem

# ---------------------------------------------------------------------------
# GitHub App (optional — enables GitHub integration features)
# ---------------------------------------------------------------------------
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
# Alternative to the _PATH variable: inline the PEM contents (escape \n)
# GITHUB_APP_PRIVATE_KEY=

# GitHub OAuth (optional — enables GitHub sign-in)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
